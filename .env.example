# =============================================================================
# IT Project OS — Przykładowe zmienne środowiskowe
# =============================================================================
# Skopiuj ten plik jako .env i uzupełnij wartości.
# NIGDY nie commituj pliku .env do repozytorium!
# =============================================================================

# --- Środowisko ---
ENVIRONMENT=development

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=it_os_db

# --- OIDC Provider (Keycloak) ---
# URL bazowy realm (bez /.well-known/openid-configuration)
OIDC_ISSUER=http://localhost:8080/realms/it-os
# URL discovery — używany przez niektóre biblioteki klienckie
OIDC_DISCOVERY_URL=http://localhost:8080/realms/it-os/.well-known/openid-configuration
OIDC_CLIENT_ID=it-project-os
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=http://localhost:5050/auth/callback
OIDC_SCOPES=openid profile email

# --- JWT / Sesja (wymagane przez shell/config.py) ---
# Algorytm weryfikacji tokenu: RS256 dla Keycloak, HS256 dla testów
JWT_ALGORITHM=RS256
# Klucz do podpisywania sesji — min. 32 znaki, losowy string
SECRET_KEY=change-me-min-32-chars-random-string
# Nazwa cookie HttpOnly przechowującego identyfikator sesji
SESSION_COOKIE_NAME=it_os_session
# Czas życia sesji w sekundach (3600 = 1 godzina)
SESSION_COOKIE_MAX_AGE=3600

# --- Adres aplikacji ---
APP_BASE_URL=http://localhost:5050

# --- CORS (lista dozwolonych origins oddzielonych przecinkami) ---
CORS_ORIGINS=http://localhost:5050,http://localhost:8001,http://localhost:8002

# --- Keycloak Admin ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@example.local
PGADMIN_DEFAULT_PASSWORD=change-me
